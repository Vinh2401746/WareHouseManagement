  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "/**\r",
          " * Generate random numeric string with given length\r",
          " */\r",
          "function randomNumberString(length) {\r",
          "  let result = '';\r",
          "  for (let i = 0; i < length; i++) {\r",
          "    result += Math.floor(Math.random() * 10);\r",
          "  }\r",
          "  return result;\r",
          "}\r",
          "\r",
          "/**\r",
          " * Random tax code\r",
          " * - 10 digits\r",
          " * - or 10 digits + '-' + 3 digits\r",
          " */\r",
          "function randomTaxCode() {\r",
          "  const first10 = randomNumberString(10);\r",
          "  const is13 = Math.random() < 0.5;\r",
          "\r",
          "  if (!is13) return first10;\r",
          "\r",
          "  return `${first10}-${randomNumberString(3)}`;\r",
          "}\r",
          "\r",
          "function randomVietnamPhone() {\r",
          "  const prefixes = ['03', '05', '07', '08', '09'];\r",
          "  const prefix = prefixes[Math.floor(Math.random() * prefixes.length)];\r",
          "\r",
          "  // Tổng 10 số → prefix (2 số) + 8 số random\r",
          "  return prefix + randomNumberString(8);\r",
          "}\r",
          "\r",
          "pm.globals.set('tax_code', randomTaxCode());\r",
          "pm.globals.set('random_8_digits', randomNumberString(8));\r",
          "pm.globals.set('phone_number', randomVietnamPhone());"
        ]
      }
    },
